  "version": "0.2.0",
  "configurations": [
    {
      "name": "node.js: debug",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run sync:local",
      "serverReadyAction": {
        "pattern": "started server on .+, url: (https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      },
      "autoAttachChildProcesses": true
    }
  ]
