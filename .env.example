# --- Jira ---
JIRA_BASE_URL=https://buivanminh.atlassian.net
JIRA_EMAIL=buivanminh1309@gmail.com
JIRA_API_TOKEN=xxxxZ
JIRA_PROJECT_KEY=SCRUM
# Optional extra JQL appended with AND, ví dụ: issuetype in (Bug, Task)
JIRA_JQL_EXTRA=

# --- Azure DevOps ---
ADO_ORG=torus-engineering
ADO_PROJECT=Tickets
ADO_PAT=xxxx
# Custom field lưu Jira key để upsert. Tạo trước trong ADO process customization.
ADO_JIRA_KEY_FIELD=Custom.JiraID

# --- State (Vercel KV / Upstash) ---
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Fallback nếu chưa có KV: lấy issues trong N phút gần nhất
SYNC_WINDOW_MINUTES=5

# --- Vercel Cron security ---
CRON_SECRET=some-long-random-string

# mongo DB
MONGODB_URI=mongodb+srv://localhost:27017/
MONGODB_DB=sync_jira_ado
MONGODB_STATE_COLLECTION=sync_state
MONGODB_LOG_COLLECTION=ado_logs
